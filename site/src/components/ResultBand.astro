---
const { result, detail } = Astro.props;
---
<div class="result rv">
  <div class="big font-display">{result}</div>
  {detail && <div class="sub">{detail}</div>}
</div>
<style>
  .result { border-top: 2px solid var(--ink); border-bottom: 1px solid var(--hairline);
            padding: 18px 0 16px; margin: 0 0 24px; }
  .big { font-weight: 600; font-size: clamp(26px, 3.4vw, 38px); line-height: 1.05;
         font-variant-numeric: tabular-nums; }
  .sub { font-family: system-ui, sans-serif; font-size: 12.5px; color: var(--slate);
         margin-top: 6px; font-variant-numeric: tabular-nums; }
</style>
