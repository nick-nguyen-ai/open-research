---
import { fmtDate } from "../lib/format.mjs";
const { reviews = [] } = Astro.props;
const AXES = [
  ["clarity", "Clarity"],
  ["claims_vs_evidence", "Claims vs evidence"],
  ["reproducibility", "Reproducibility"]
];
const WORD = { "strong": "Strong", "adequate": "Adequate", "needs-work": "Needs work" };
---
{reviews.length > 0 && (
  <section class="pr" aria-label="Peer review">
    <h2 class="caps prh">Peer review</h2>
    {reviews.map((r) => (
      <article class="prv rv">
        <header class="prhead">
          <span class="who">
            {r.reviewer.kind === "human"
              ? <Fragment>Reviewed by <b>{r.reviewer.name}</b> · {r.reviewer.team}</Fragment>
              : <Fragment>Machine referee · <b>{r.reviewer.model}</b></Fragment>}
          </span>
          <span class="when">{fmtDate(r.date, "long")}</span>
        </header>
        <dl class="scorecard">
          {AXES.map(([key, label]) => (
            <div class={`ax ax-${r.verdicts[key]}`}>
              <dt>{label}</dt>
              <dd>{WORD[r.verdicts[key]]}</dd>
            </div>
          ))}
        </dl>
        <p class="stmt">{r.statement}</p>
        {r.suggestions.length > 0 && (
          <ul class="sugg">
            {r.suggestions.map((s) => <li>{s}</li>)}
          </ul>
        )}
        {r.override && (
          <div class="dissent">
            <span class="dk">Published with dissenting review</span>
            <p class="dr">“{r.override.reason}”</p>
            <span class="db">— {r.override.by}, {fmtDate(r.override.date, "short")}</span>
          </div>
        )}
      </article>
    ))}
  </section>
)}
<style>
  .pr { border-top: 2px solid var(--ink); margin-top: 36px; padding-top: 14px; }
  .prh { color: var(--slate); margin-bottom: 4px; }
  .prv { border-bottom: 1px solid var(--hairline); padding: 18px 0 20px; }
  .prv:last-child { border-bottom: none; }
  .prhead { display: flex; justify-content: space-between; gap: 12px; flex-wrap: wrap;
            font-family: system-ui, sans-serif; font-size: 12.5px; color: var(--slate); }
  .prhead b { color: var(--ink); }
  .when { font-variant-numeric: tabular-nums; }
  .scorecard { display: flex; gap: 28px; flex-wrap: wrap; margin: 14px 0 12px; }
  .ax dt { font-family: system-ui, sans-serif; font-size: 10.5px; letter-spacing: .14em;
           text-transform: uppercase; color: var(--slate); margin-bottom: 2px; }
  .ax dd { font-family: var(--font-display); font-weight: 600; font-size: 16px; margin: 0; }
  .ax-strong dd { color: var(--verified); }
  .ax-adequate dd { color: var(--ink); }
  .ax-needs-work dd { color: var(--oxblood); font-style: italic; }
  .stmt { font-family: var(--font-prose); font-size: 15.5px; line-height: 1.65; margin: 0; max-width: 62ch; }
  .sugg { font-family: system-ui, sans-serif; font-size: 12.5px; color: var(--slate);
          margin: 10px 0 0; padding-left: 18px; max-width: 62ch; }
  .sugg li { margin: 4px 0; }
  /* The signature block: the objection and the author's answer, both on the record. */
  .dissent { border: 1px solid var(--oxblood); padding: 12px 16px 13px; margin-top: 16px; max-width: 58ch; }
  .dk { font-family: system-ui, sans-serif; font-size: 10.5px; letter-spacing: .16em;
        text-transform: uppercase; color: var(--oxblood); font-weight: 600; }
  .dr { font-family: var(--font-prose); font-style: italic; font-size: 14.5px;
        line-height: 1.6; margin: 8px 0 6px; }
  .db { font-family: system-ui, sans-serif; font-size: 11.5px; color: var(--slate); }
</style>
