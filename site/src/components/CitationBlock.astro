---
import { fmtDate, tierLabel } from "../lib/format.mjs";
const { fm, slug, rev } = Astro.props;
const authors = fm.authors.map((a) => `${a.name} (${a.team})`).join(", ");
const line = `${authors}. ${fm.title}. OpenResearch, ${tierLabel(fm.tier).toLowerCase()}/${fm.category}, ${fmtDate(fm.updated, "long")}.`;
const ref = `/contributions/${slug}${rev ? ` · rev ${rev}` : ""}`;
---
<div class="cite rv">
  <div class="ch"><span>Reference this contribution</span>
    <button type="button" data-copy="#citation-text">Copy</button></div>
  <div class="cb" id="citation-text">{line}{" "}{ref}</div>
</div>
<style>
  .cite { border: 1px solid var(--hairline); border-radius: 8px; margin-top: 30px; overflow: hidden; }
  .ch { display: flex; justify-content: space-between; align-items: center;
        font-family: system-ui, sans-serif; font-size: 10.5px; letter-spacing: .18em;
        text-transform: uppercase; color: var(--slate); background: var(--soft);
        padding: 9px 16px; border-bottom: 1px solid var(--hairline); }
  .ch button { font-family: system-ui, sans-serif; font-size: 11px; letter-spacing: .05em;
               color: var(--oxblood); background: none; border: 1px solid var(--oxblood);
               border-radius: 4px; padding: 3px 10px; cursor: pointer; transition: all .2s; }
  .ch button:hover { background: var(--oxblood); color: var(--paper); }
  .cb { font-family: ui-monospace, Consolas, monospace; font-size: 12px; color: var(--slate);
        padding: 13px 16px; line-height: 1.6; overflow-x: auto; }
</style>
