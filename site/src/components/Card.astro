---
import { tierLabel } from "../lib/format.mjs";
const { card } = Astro.props;
---
<a class="card rv" href={`/contributions/${card.slug}`} data-tier={card.tier}>
  <span class="caps"><span class="card-tierword">{tierLabel(card.tier)}</span> · {card.category}</span>
  <h3 transition:name={`title-${card.slug}`}>{card.title}</h3>
  {card.result && <div class="card-result">{card.result}</div>}
  <p class="card-summary">{card.summary}</p>
  <div class="card-ev">
    <span class={card.replications > 0 ? "ev-verified" : ""}><b>{card.replications}</b> replication{card.replications === 1 ? "" : "s"}</span>
    <span><b>{card.teams}</b> team{card.teams === 1 ? "" : "s"}</span>
    {card.reviewStatus === "human" && <span class="ev-verified">peer-reviewed</span>}
    {card.reviewStatus === "machine" && <span>machine-reviewed</span>}
  </div>
</a>
