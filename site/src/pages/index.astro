---
import Base from "../layouts/Base.astro";
import Masthead from "../components/Masthead.astro";
import Footer from "../components/Footer.astro";
import Card from "../components/Card.astro";
import stats from "../data/stats.json";
import cards from "../data/cards.json";
import { tierLabel } from "../lib/format.mjs";

const featured = cards.find((c) => c.replications > 0 && c.result) ?? cards[0];
const verified = cards.filter((c) => c.replications > 0 && c.slug !== featured.slug).slice(0, 4);
const recent = cards.filter((c) => c.slug !== featured.slug && !verified.includes(c)).slice(0, 6);
---
<Base>
  <main class="max-w-[1080px] mx-auto px-6 pt-8">
    <Masthead />
    <section class="hero">
      <div class="hero-pitch">
        <p class="caps">The internal record of applied AI research</p>
        <h1 class="font-display">Findings your colleagues have <em>already verified.</em></h1>
        <p class="stand">Nothing here is a claim. Every technique carries its evidence — who replicated it,
          on which benchmark, what it measurably changed — so you can adopt results, not opinions.</p>
        <div class="cta-row">
          <a class="abtn abtn-primary" href={`/contributions/${featured.slug}`}>Read a verified finding</a>
          <a class="abtn" href="/contribute">Contribute in 15 minutes</a>
          <a class="abtn" href="/toolkit">Install the toolkit</a>
        </div>
        <div class="statline caps">
          <div><b data-count-to={stats.contributions}>0</b><span>contributions</span></div>
          <div><b data-count-to={stats.replications}>0</b><span>replications</span></div>
          <div><b data-count-to={stats.teams}>0</b><span>teams verifying</span></div>
        </div>
      </div>
      <a class="hero-proof" href={`/contributions/${featured.slug}`} data-tier={featured.tier}>
        <span class="caps proof-eyebrow"><span class="proof-tier">{tierLabel(featured.tier)}</span> · verified by {featured.teams} team{featured.teams === 1 ? "" : "s"}</span>
        <div class="proof-result font-display">{featured.result}</div>
        <div class="proof-title font-display">{featured.title}</div>
        <span class="proof-more caps">Read the evidence →</span>
      </a>
    </section>

    <div class="seclab"><span class="caps" style="color: var(--oxblood)">Verified findings</span></div>
    <div class="cards">
      {verified.map((card) => <Card card={card} />)}
    </div>

    {recent.length > 0 && (
      <>
        <div class="seclab"><span class="caps">Recently published</span></div>
        <div class="cards">
          {recent.map((card) => <Card card={card} />)}
        </div>
      </>
    )}
    <Footer />
  </main>
</Base>
<style>
  .hero { padding: 50px 0 42px; border-bottom: 1px solid var(--hairline);
          display: grid; grid-template-columns: minmax(0, 1.5fr) minmax(260px, 1fr);
          gap: 48px; align-items: start; }
  .hero h1 { font-weight: 600; font-size: clamp(30px, 4.2vw, 46px); line-height: 1.12;
             margin: 14px 0 16px; max-width: 21ch; text-wrap: balance; }
  .hero h1 em { font-style: italic; font-weight: 500; color: var(--oxblood); }
  .stand { max-width: 52ch; color: var(--slate); margin: 0 0 24px; font-size: 16.5px; }
  .cta-row { display: flex; gap: 10px; flex-wrap: wrap; margin: 0 0 28px; }
  .cta-row .abtn { font-size: 13.5px; padding: 8px 18px; }
  .statline { display: flex; gap: 26px; flex-wrap: wrap; }
  .statline b { font-family: var(--font-display); font-weight: 600; font-size: 30px;
                display: block; font-variant-numeric: tabular-nums; color: var(--ink); }

  .hero-proof { display: block; text-decoration: none; color: inherit;
                border-top: 3px solid var(--tier, var(--ink));
                background: var(--soft); padding: 22px 24px 20px; margin-top: 34px;
                transition: background .3s; }
  .hero-proof:hover { background: color-mix(in srgb, var(--soft) 60%, var(--paper)); }
  .proof-tier { color: var(--tier, var(--slate)); }
  .proof-result { font-weight: 600; font-size: clamp(28px, 3vw, 36px); line-height: 1.05;
                  margin: 12px 0 10px; font-variant-numeric: tabular-nums; }
  .proof-title { font-weight: 600; font-size: 17px; line-height: 1.3; margin: 0 0 14px;
                 text-wrap: balance; transition: color .25s; }
  .hero-proof:hover .proof-title { color: var(--oxblood); }
  .proof-more { color: var(--oxblood); }

  .seclab { display: flex; align-items: center; gap: 14px; margin: 34px 0 0; }
  .seclab::after { content: ""; flex: 1; border-top: 1px solid var(--hairline); }
  .cards { display: grid; grid-template-columns: 1fr 1fr; border-top: 1px solid var(--hairline); margin-top: 16px; }
  .cards > :global(.card:nth-child(odd)) { border-right: 1px solid var(--hairline); }
  @media (max-width: 860px) {
    .hero { grid-template-columns: 1fr; gap: 8px; }
    .hero-proof { margin-top: 18px; }
  }
  @media (max-width: 720px) {
    .cards { grid-template-columns: 1fr; }
    .cards > :global(.card:nth-child(odd)) { border-right: none; }
  }
</style>
