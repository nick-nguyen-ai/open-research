---
import Base from "../layouts/Base.astro";
import Masthead from "../components/Masthead.astro";
import Footer from "../components/Footer.astro";
import Card from "../components/Card.astro";
import stats from "../data/stats.json";
import cards from "../data/cards.json";
import arena from "../data/arena.json";
import toolkit from "../data/toolkit.json";
import evidence from "../data/evidence.json";
import { tierLabel, fmtDate } from "../lib/format.mjs";

const featured = cards.find((c) => c.replications > 0 && c.result) ?? cards[0];
const latest = cards.filter((c) => c.replications > 0 && c.slug !== featured.slug).slice(0, 3);

// The evidence specimen is real: heading-aware-chunking's live records,
// including the partial — the honesty is the pitch.
const ev = evidence["heading-aware-chunking"] ?? { replications: [], adoptions: [] };
const OUTCOME = { replicated: "Verified", partial: "Partial", failed: "Failed", active: "Active", trialing: "Trialing" };
const specimen = [
  ...ev.replications.slice(0, 3).map((r) => ({
    kind: "Replication", team: r.team, line: r.delta, meta: `${r.benchmark} · ${fmtDate(r.date, "short")}`, outcome: r.outcome
  })),
  ...ev.adoptions.slice(0, 1).map((a) => ({
    kind: "Adoption", team: a.team, line: a.impact ?? a.pipeline, meta: `in production since ${fmtDate(a.since, "short")}`, outcome: a.status
  }))
];

const top3 = arena.individuals.slice(0, 3);
const maxScore = top3[0]?.score || 1;
const shipped = toolkit.skills.filter((s) => !s.shipsIn);

const steps = [
  { n: "01", t: "Read", copy: "Open any finding and its evidence is already in the margin: who replicated it, on which benchmark, what measurably changed. No claim stands alone.", href: "/browse", link: "Browse the record" },
  { n: "02", t: "Try", copy: "Every contribution ships a replication bundle — a protocol you can run against your own workflow this afternoon. Partial and failed outcomes publish too; honesty is the house style.", href: `/contributions/using-openresearch`, link: "Follow the tutorial" },
  { n: "03", t: "Publish", copy: "Copy a tier template, or hand the publish skill a braindump. A machine referee reviews every submission before the merge — publish clean, or over its objection with your reason on the record.", href: "/contribute", link: "The 15-minute flow" },
];
---
<Base>
  <main class="max-w-[1080px] mx-auto px-6 pt-8">
    <Masthead home />

    <!-- ── Hero ─────────────────────────────────────────────── -->
    <section class="hero">
      <div class="hero-pitch">
        <div class="rv folio-row">
          <p class="caps">The internal record of applied AI research</p>
          <p class="caps folio">Vol. I · Est. July 2026</p>
        </div>
        <h1 class="rv font-display">Findings your colleagues have <em>already verified.</em></h1>
        <p class="rv stand">Nothing here is a claim. Every technique carries its evidence — who replicated it,
          on which benchmark, what it measurably changed — so you adopt results, not opinions.</p>
        <div class="rv cta-row">
          <a class="abtn abtn-primary" href={`/contributions/${featured.slug}`}>Read a verified finding</a>
          <a class="abtn" href="/contribute">Contribute in 15 minutes</a>
          <a class="abtn" href="/toolkit">Install the toolkit</a>
        </div>
        <div class="rv statline caps">
          <div><b data-count-to={stats.contributions}>0</b><span>contributions</span></div>
          <div><b data-count-to={stats.replications}>0</b><span>replications</span></div>
          <div><b data-count-to={stats.teams}>0</b><span>teams verifying</span></div>
        </div>
      </div>
      <a class="rv hero-proof" href={`/contributions/${featured.slug}`} data-tier={featured.tier}>
        <span class="caps proof-eyebrow"><span class="proof-tier">{tierLabel(featured.tier)}</span> · verified by {featured.teams} team{featured.teams === 1 ? "" : "s"}</span>
        <div class="proof-result font-display">{featured.result}</div>
        <div class="proof-title font-display">{featured.title}</div>
        <span class="proof-more caps">Read the evidence →</span>
        <span class="stamp proof-stamp">evidence attached</span>
      </a>
    </section>

    <!-- ── The loop ─────────────────────────────────────────── -->
    <section class="lsec">
      <div class="rv lsec-head"><span class="caps" style="color: var(--oxblood)">The loop</span></div>
      <h2 class="rv font-display lsec-title">Read it. Run it. <em>Publish yours.</em></h2>
      <div class="steps">
        {steps.map((s) => (
          <div class="rv step">
            <div class="step-n font-display">{s.n}</div>
            <div class="step-t font-display">{s.t}</div>
            <p class="step-copy">{s.copy}</p>
            <a class="step-link caps" href={s.href}>{s.link} →</a>
          </div>
        ))}
      </div>
    </section>

    <!-- ── The culture ──────────────────────────────────────── -->
    <section class="lsec">
      <div class="rv lsec-head"><span class="caps" style="color: var(--oxblood)">The culture</span></div>
      <div class="proofgrid">
        <div class="proofcopy">
          <h2 class="rv font-display lsec-title">Proof, not promises —<br /><em>including the proofs that failed.</em></h2>
          <p class="rv pc">Replications earn as much standing as authorship, and negative results stay published.
            When our own rerun of heading-aware chunking came back at parity, it went up as
            <b>partial</b> — the recall gain didn't transfer, the 66% smaller index did.
            That page is still live. That's the point.</p>
          <a class="rv step-link caps" href="/contributions/heading-aware-chunking">See its evidence panel →</a>
        </div>
        <div class="rv specimen" aria-label="Live evidence records for heading-aware chunking">
          <div class="spine"></div>
          {specimen.map((s) => (
            <div class="spec-row">
              <span class="spec-dot"></span>
              <span class="spec-k caps">{s.kind} · {s.team}</span>
              <span class="spec-line">{s.line}</span>
              <span class="spec-meta">{s.meta} · <span class={s.outcome === "replicated" || s.outcome === "active" ? "seal spec-seal" : "stamp"}>{OUTCOME[s.outcome] ?? s.outcome}</span></span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ── The toolkit ──────────────────────────────────────── -->
    <section class="lsec">
      <div class="rv lsec-head"><span class="caps" style="color: var(--oxblood)">The toolkit</span></div>
      <div class="tkgrid">
        <div>
          <h2 class="rv font-display lsec-title">The whole loop runs from <em>Claude Code.</em></h2>
          <p class="rv pc">Five instruction-only skills — no API keys, no provider lock-in. Read a paper properly,
            turn a rerun into a replication record, get an advisory review, publish as a pull request.</p>
          <a class="rv step-link caps" href="/toolkit">See it in action →</a>
        </div>
        <div class="rv tkterm" data-tier="tutorial">
          <div class="tkbar"><span></span><span></span><span></span></div>
          <div class="tkline"><span class="tkprompt">$</span> {toolkit.install.init}<span class="caret"></span></div>
          <div class="tkskills">
            {shipped.map((s) => <span class="kbd">{s.name}</span>)}
          </div>
        </div>
      </div>
    </section>

    <!-- ── The arena ────────────────────────────────────────── -->
    <section class="lsec">
      <div class="rv lsec-head"><span class="caps" style="color: var(--oxblood)">The arena</span></div>
      <div class="argrid">
        <div>
          <h2 class="rv font-display lsec-title">Verifying earns like <em>authoring.</em></h2>
          <p class="rv pc">Rank is weighted to what other teams confirmed: independent replications, adoption in
            real pipelines, measured deltas. Same-team replications score zero — the rules are non-gameable
            and public.</p>
          <a class="rv step-link caps" href="/arena">See the full boards →</a>
        </div>
        <div class="arboard">
          {top3.map((p, i) => (
            <a class="rv arrow" href={`/people/${p.handle}`}>
              <span class="ar-rank font-display">{i + 1}</span>
              <span class="ar-who">
                <b>{p.name}</b>
                <span class="ar-team">{p.team}</span>
              </span>
              <span class="ar-barwrap"><span class="ar-bar" style={`--w:${Math.round((p.score / maxScore) * 100)}%`}></span></span>
              <span class="ar-score font-display">{p.score}</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- ── Latest verified ──────────────────────────────────── -->
    <section class="lsec">
      <div class="rv lsec-head lsec-head-split">
        <span class="caps" style="color: var(--oxblood)">Latest verified</span>
        <a class="caps browse-all" href="/browse">All {stats.contributions} contributions →</a>
      </div>
      <div class="cards3">
        {latest.map((card) => <Card card={card} />)}
      </div>
    </section>

    <!-- ── Closing ──────────────────────────────────────────── -->
    <section class="closing">
      <p class="rv font-display closing-line">Your next finding is <em>a fifteen-minute pull request.</em></p>
      <div class="rv"><a class="abtn abtn-primary" href="/contribute">Start contributing</a></div>
    </section>

    <Footer />
  </main>
</Base>

<style>
  /* ── hero ── */
  .hero { padding: 50px 0 46px; border-bottom: 1px solid var(--hairline);
          display: grid; grid-template-columns: minmax(0, 1.5fr) minmax(260px, 1fr);
          gap: 48px; align-items: start; }
  .folio-row { display: flex; justify-content: space-between; gap: 16px; align-items: baseline; }
  .folio { color: var(--hairline); color: color-mix(in srgb, var(--slate) 55%, transparent); letter-spacing: .16em; }
  .hero h1 { font-weight: 600; font-size: clamp(30px, 4.2vw, 46px); line-height: 1.12;
             margin: 14px 0 16px; max-width: 21ch; text-wrap: balance; }
  .hero h1 em { font-style: italic; font-weight: 500; color: var(--oxblood); }
  .stand { max-width: 52ch; color: var(--slate); margin: 0 0 24px; font-size: 16.5px; }
  .cta-row { display: flex; gap: 10px; flex-wrap: wrap; margin: 0 0 28px; }
  .cta-row .abtn { font-size: 13.5px; padding: 8px 18px; }
  .statline { display: flex; gap: 26px; flex-wrap: wrap; }
  .statline b { font-family: var(--font-display); font-weight: 600; font-size: 30px;
                display: block; font-variant-numeric: tabular-nums; color: var(--ink); }

  .hero-proof { position: relative; display: block; text-decoration: none; color: inherit;
                border-top: 3px solid var(--tier, var(--ink));
                background: var(--soft); padding: 22px 24px 20px; margin-top: 34px;
                transition: background .3s; }
  .hero-proof:hover { background: color-mix(in srgb, var(--soft) 60%, var(--paper)); }
  .proof-tier { color: var(--tier, var(--slate)); }
  .proof-result { font-weight: 600; font-size: clamp(28px, 3vw, 36px); line-height: 1.05;
                  margin: 12px 0 10px; font-variant-numeric: tabular-nums;
                  transition: clip-path 1s cubic-bezier(.2,.6,.2,1) .35s; }
  :global(html.js) .hero-proof:not(.on) .proof-result { clip-path: inset(0 100% 0 0); }
  .hero-proof.on .proof-result { clip-path: inset(-2px 0); }
  .proof-title { font-weight: 600; font-size: 17px; line-height: 1.3; margin: 0 0 14px;
                 text-wrap: balance; transition: color .25s; }
  .hero-proof:hover .proof-title { color: var(--oxblood); }
  .proof-more { color: var(--oxblood); }
  .proof-stamp { position: absolute; top: 18px; right: -10px; }

  /* ── landing sections ── */
  .lsec { padding: 44px 0 8px; }
  .lsec-head { display: flex; align-items: center; gap: 14px; }
  .lsec-head::after { content: ""; flex: 1; border-top: 1px solid var(--hairline); }
  .lsec-head-split { justify-content: space-between; }
  .lsec-head-split::after { display: none; }
  .browse-all { color: var(--oxblood); text-decoration: none; }
  .browse-all:hover { text-decoration: underline; }
  .lsec-title { font-weight: 600; font-size: clamp(24px, 3vw, 32px); line-height: 1.18;
                margin: 18px 0 14px; text-wrap: balance; max-width: 24ch; }
  .lsec-title em { font-style: italic; font-weight: 500; color: var(--oxblood); }
  .pc { color: var(--slate); font-size: 15.5px; max-width: 54ch; margin: 0 0 16px; }
  .pc b { color: var(--ink); }

  /* ── steps ── */
  .steps { display: grid; grid-template-columns: repeat(3, 1fr); gap: 34px; margin-top: 22px; }
  .step { border-top: 2px solid var(--ink); padding-top: 14px; position: relative; }
  .step::before { content: ""; position: absolute; top: -2px; left: 0; height: 2px; width: 100%;
                  background: var(--oxblood); transform-origin: left;
                  transition: transform .9s cubic-bezier(.2,.6,.2,1) .15s; }
  :global(html.js) .step:not(.on)::before { transform: scaleX(0); }
  .step-n { font-weight: 600; font-size: 15px; color: var(--oxblood); font-variant-numeric: tabular-nums; }
  .step-t { font-weight: 600; font-size: 22px; margin: 2px 0 8px; }
  .step-copy { color: var(--slate); font-size: 14.5px; margin: 0 0 12px; }
  .step-link { color: var(--oxblood); text-decoration: none; letter-spacing: .14em; }
  .step-link:hover { text-decoration: underline; }

  /* ── evidence specimen ── */
  .proofgrid { display: grid; grid-template-columns: minmax(0, 1.1fr) minmax(280px, 1fr); gap: 48px; align-items: start; }
  .specimen { position: relative; padding-left: 26px; display: flex; flex-direction: column; gap: 20px; margin-top: 20px; }
  .spine { position: absolute; left: 0; top: 4px; bottom: 4px; width: 1px; background: var(--hairline);
           transform-origin: top; transition: transform 1.1s cubic-bezier(.2,.6,.2,1) .1s; }
  :global(html.js) .specimen:not(.on) .spine { transform: scaleY(0); }
  .spec-row { position: relative; font-family: system-ui, sans-serif; font-size: 12.5px; color: var(--slate); line-height: 1.55; }
  .spec-dot { position: absolute; left: -30px; top: 4px; width: 8px; height: 8px; border-radius: 50%;
              background: var(--paper); border: 2px solid var(--verified);
              transition: transform .45s cubic-bezier(.2,.9,.3,1.4); }
  :global(html.js) .specimen:not(.on) .spec-dot { transform: scale(0); }
  .specimen.on .spec-row:nth-child(2) .spec-dot { transition-delay: .35s; }
  .specimen.on .spec-row:nth-child(3) .spec-dot { transition-delay: .55s; }
  .specimen.on .spec-row:nth-child(4) .spec-dot { transition-delay: .75s; }
  .specimen.on .spec-row:nth-child(5) .spec-dot { transition-delay: .95s; }
  .spec-k { display: block; color: var(--verified); letter-spacing: .16em; margin-bottom: 3px; }
  .spec-line { display: block; color: var(--ink); font-weight: 600; font-variant-numeric: tabular-nums; }
  .spec-meta { display: block; font-size: 11px; margin-top: 3px; }
  .spec-seal { padding: 2px 7px; font-size: 9.5px; }
  .spec-meta .stamp { font-size: 9px; }

  /* ── toolkit terminal ── */
  .tkgrid, .argrid { display: grid; grid-template-columns: minmax(0, 1.1fr) minmax(280px, 1fr); gap: 48px; align-items: center; }
  .tkterm { border: 1px solid var(--hairline); border-top: 3px solid var(--tier, var(--ink));
            background: var(--soft); padding: 0 0 16px; }
  .tkbar { display: flex; gap: 6px; padding: 12px 16px 10px; border-bottom: 1px solid var(--hairline); }
  .tkbar span { width: 9px; height: 9px; border-radius: 50%; background: var(--hairline); }
  .tkline { font-family: ui-monospace, Consolas, monospace; font-size: 14px; color: var(--ink);
            padding: 18px 18px 14px; }
  .tkprompt { color: var(--oxblood); margin-right: 8px; }
  .caret { display: inline-block; width: 8px; height: 15px; background: var(--oxblood);
           margin-left: 6px; vertical-align: text-bottom; animation: blink 1.1s steps(1) infinite; }
  @keyframes blink { 50% { opacity: 0; } }
  @media (prefers-reduced-motion: reduce) { .caret { animation: none; } }
  .tkskills { display: flex; gap: 8px; flex-wrap: wrap; padding: 0 18px; }

  /* ── arena teaser ── */
  .arboard { display: flex; flex-direction: column; border-top: 2px solid var(--ink); }
  .arrow { display: grid; grid-template-columns: 30px minmax(110px, auto) 1fr 44px; gap: 14px;
           align-items: center; padding: 13px 4px; border-bottom: 1px solid var(--hairline);
           text-decoration: none; color: inherit; transition: background .3s; }
  .arrow:hover { background: var(--soft); }
  .ar-rank { font-weight: 600; font-size: 18px; color: var(--slate); font-variant-numeric: tabular-nums; }
  .arrow:first-of-type .ar-rank { color: var(--oxblood); }
  .ar-who { display: flex; flex-direction: column; font-family: system-ui, sans-serif; font-size: 13.5px; }
  .ar-who b { color: var(--ink); }
  .arrow:hover .ar-who b { color: var(--oxblood); }
  .ar-team { font-size: 11px; color: var(--slate); }
  .ar-barwrap { height: 4px; background: var(--soft); border-radius: 2px; overflow: hidden; }
  .ar-bar { display: block; height: 100%; background: var(--oxblood); width: var(--w);
            transition: width 1s cubic-bezier(.2,.6,.2,1) .25s; border-radius: 2px; }
  :global(html.js) .arrow:not(.on) .ar-bar { width: 0; }
  .ar-score { font-weight: 600; font-size: 19px; text-align: right; font-variant-numeric: tabular-nums; }

  /* ── latest verified ── */
  .cards3 { display: grid; grid-template-columns: repeat(3, 1fr); border-top: 1px solid var(--hairline); margin-top: 16px; }
  .cards3 > :global(.card:not(:last-child)) { border-right: 1px solid var(--hairline); }

  /* ── closing ── */
  .closing { border-top: 1px solid var(--hairline); margin-top: 40px; padding: 52px 0 26px; text-align: center; }
  .closing-line { font-weight: 600; font-size: clamp(24px, 3.4vw, 36px); line-height: 1.2;
                  margin: 0 0 22px; text-wrap: balance; }
  .closing-line em { font-style: italic; font-weight: 500; color: var(--oxblood); }

  /* ── responsive ── */
  @media (max-width: 860px) {
    .hero, .proofgrid, .tkgrid, .argrid { grid-template-columns: 1fr; gap: 20px; }
    .hero-proof { margin-top: 12px; }
    .steps { grid-template-columns: 1fr; gap: 22px; }
    .cards3 { grid-template-columns: 1fr; }
    .cards3 > :global(.card:not(:last-child)) { border-right: none; }
  }
</style>
