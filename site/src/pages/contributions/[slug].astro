---
import { getCollection, render } from "astro:content";
import Base from "../../layouts/Base.astro";
import Masthead from "../../components/Masthead.astro";
import Footer from "../../components/Footer.astro";
import ActionRow from "../../components/ActionRow.astro";
import ResultBand from "../../components/ResultBand.astro";
import CitationBlock from "../../components/CitationBlock.astro";
import ContentsList from "../../components/ContentsList.astro";
import Rail from "../../components/Rail.astro";
import Changelog from "../../components/Changelog.astro";
import Discussions from "../../components/Discussions.astro";
import evidence from "../../data/evidence.json";
import { fmtDate, readTime, tierLabel, slugifyName } from "../../lib/format.mjs";

export async function getStaticPaths() {
  const entries = await getCollection("contributions", (e) => e.data.status === "published");
  return entries.map((entry) => ({ params: { slug: entry.id.split("/")[0] }, props: { entry } }));
}

const { entry } = Astro.props;
const slug = entry.id.split("/")[0];
const fm = entry.data;
const tier = fm.tier;
const { Content, headings } = await render(entry);
const h2s = headings.filter((h) => h.depth === 2);
const ev = evidence[slug] ?? { replications: [], endorsements: [], adoptions: [], changelog: [], rev: null };
const adoptions = ev.adoptions ?? [];
const isNote = tier === "note";
const showBand = Boolean(fm.result) && (tier === "finding" || tier === "technical-report" || tier === "research-paper");
const verified = ev.replications.filter((r) => r.outcome === "replicated").length;
---
<Base title={`${fm.title} · OpenResearch`} description={fm.title}>
  <main class="max-w-[1080px] mx-auto px-6 pt-8">
    <Masthead active="browse" />
    <div class={`rgrid ${isNote ? "rgrid-note" : ""}`}>
      <article class={`art tier-${tier}`} data-tier={tier} data-pagefind-body
               data-pagefind-meta={`tier:${tierLabel(tier)}, category:${fm.category}, evidence:${verified} replications`}>
        <span class="caps">
          <span class="tierword">{tierLabel(tier)}</span> · {fm.category}{isNote && ` · ${fmtDate(fm.updated, "full")}`}
        </span>
        <h1 class="font-display rt" transition:name={`title-${slug}`}>{fm.title}</h1>
        <p class="byline">
          {fm.authors.map((a, i) => <Fragment>{i > 0 && ", "}<a class="pl" href={`/people/${slugifyName(a.name)}`}><b>{a.name}</b></a> · {a.team}</Fragment>)}
          {" "}· {fmtDate(fm.updated, "long")}{!isNote && ` · ${readTime(entry.body)}`}
        </p>
        {!isNote && <ActionRow slug={slug} bundle={fm.replication_bundle} benchmarks={fm.benchmarks ?? []} />}
        {showBand && <ResultBand result={fm.result} detail={fm.result_detail} />}
        {(tier === "technical-report" || tier === "research-paper") && <ContentsList headings={h2s} />}
        <div class="article-body">
          <Content />
        </div>
        <Changelog items={ev.changelog ?? []} />
        {!isNote && <CitationBlock fm={fm} slug={slug} rev={ev.rev} />}
        {isNote && (
          <div class="notebar">
            <span>
              {verified} replication{verified === 1 ? "" : "s"}
              {adoptions.length > 0 ? ` · ${adoptions.length} adoption${adoptions.length === 1 ? "" : "s"}` : ""}
            </span>
            <a href="/contribute">Tried it? Add evidence →</a>
          </div>
        )}
        <Discussions slug={slug} />
      </article>
      {!isNote && <Rail headings={h2s} replications={ev.replications} endorsements={ev.endorsements} adoptions={adoptions} />}
    </div>
    <Footer />
  </main>
</Base>
<style>
  .rgrid { display: grid; grid-template-columns: minmax(0, 1.85fr) minmax(215px, 1fr);
           gap: 42px; padding-top: 36px; }
  .rgrid-note { grid-template-columns: minmax(0, 640px); justify-content: center; }
  @media (max-width: 760px) { .rgrid { grid-template-columns: 1fr; } }
  .rt { font-weight: 600; font-size: 30px; line-height: 1.15; margin: 10px 0 8px; text-wrap: balance; }
  .tierword { color: var(--tier, var(--slate)); }
  .byline { font-family: system-ui, sans-serif; font-size: 12.5px; color: var(--slate); margin-bottom: 20px; }
  .byline b { color: var(--ink); }
  .byline a.pl { color: inherit; text-decoration: none; border-bottom: 1px solid var(--hairline); }
  .byline a.pl:hover { border-color: var(--oxblood); }
  .notebar { font-family: system-ui, sans-serif; font-size: 11.5px; color: var(--slate);
             border-top: 1px solid var(--hairline); margin-top: 24px; padding-top: 12px;
             display: flex; justify-content: space-between; gap: 10px; flex-wrap: wrap; }
  .notebar a { color: var(--oxblood); text-decoration: none; }
</style>
